[Connection]
connection_type = serial
# mapped to env device provided, leave for docker-compose
serial_port = /dev/meshcore-usb
# hostname = 192.168.1.100
# tcp_port = 5555
# ble_device_name = MeshCore
timeout = 30

[Bot]
bot_name = CommunityBot
enabled = true
rate_limit_seconds = 10
bot_tx_rate_limit_seconds = 1.0
tx_delay_ms = 250
timezone = America/Denver
bot_latitude =
bot_longitude =
db_path = /app/data/meshcore_bot.db
advert_interval_hours = 24
startup_advert = flood
auto_manage_contacts = bot

[Coordinator]
# URL of the central MeshCore Coordinator API
# Leave empty to run in standalone mode (no coordination)
url = https://coordinator.denvermc.com
# Registration key (required - obtain from network admin)
registration_key =
# IATA-style mesh region code (e.g., DEN, LAX)
mesh_region = 
# Heartbeat interval in seconds
heartbeat_interval = 30
# Timeout for coordination requests in milliseconds (must accommodate 300ms bidding window)
timeout_ms = 500
# Batch reporting interval in seconds
batch_interval = 5
# Maximum batch size before forced flush
batch_size = 50

[Channels]
monitor_channels = #bot
respond_to_dms = true

[Discord]
# Discord webhook URLs - set via environment variables for security
# DISCORD_BOT_WEBHOOK_URL
bot_webhook_url =
# DISCORD_EMERGENCY_WEBHOOK_URL
emergency_webhook_url =
# Channel to rebroadcast emergency messages to
emergency_broadcast_channel =

[Web_Viewer]
enabled = true
host = 0.0.0.0
port = 8081
auto_start = true

[Logging]
log_level = INFO
log_file = logs/community_bot.log
colored_output = true

[External_Data]
n2yo_api_key =
airnow_api_key =

[Keywords]
# Available placeholders (message-based):
# {sender} - Name/ID of message sender
# {connection_info} - Path info, SNR(last hop), and RSSI(last hop) combined (e.g., "01,5f (2 hops) | SNR: 15 dB | RSSI: -120 dBm")
# {snr} - Signal-to-noise ratio of last hop in dB
# {rssi} - Received signal strength indicator of last hop in dBm
# {timestamp} - Message timestamp in HH:MM:SS format
# {path} - Message routing path (e.g., "01,5f (2 hops)")
# {path_distance} - Total distance between all hops in path with locations (e.g., "123.4km (3 segs, 1 no-loc)")
# {firstlast_distance} - Distance between first and last repeater in path (e.g., "45.6km" or empty if locations missing)
# {elapsed} - Elapsed time (e.g. 1234ms) or "Sync Device Clock" when device clock is invalid (use {elapsed} only; do not append ms)
ping = Pong
test = "@[{sender}]{phrase_part} | {path} | Dist Travel: {path_distance} in {elapsed}"
help = "Bot Help: (t)est, ping, (p)ath, channels, (mt)multitest, prefix, sun, moon, solar, dice, roll, joke | More: 'help <cmnd>'"
cmd = "Bot Cmds: test, ping, help, path, channels, mt, prefix, sun, moon, solar, dice, roll, joke, stats"

[Channels_List]
testing = Test channel
bot = Bot communication
weather = Weather updates and conditions
emergency = Emergency communications and alerts
den = Denver or your local
local.den = Denver metro
local.fnl = Fort Collins-Loveland
local.cos = Colorado Springs
emergency.emergency = Emergency communications and alerts
emergency.weather = Weather updates and conditions
emergency.traffic = Traffic updates and road conditions
emergency.hamradio = Amateur radio emergency net

[Banned_Users]
banned_users =

[Admin_ACL]
admin_pubkeys =
admin_commands =
